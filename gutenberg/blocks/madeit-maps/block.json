    "description": "A customizable Gutenberg maps block using Leaflet.js",

    "status": "nieuw",
    "madeit": {
        "changelog": {
            "1.0.0": [
                "Nieuw toegevoegd: eerste versie van de maps block met Leaflet.js integratie.",
                "Ondersteuning voor OpenStreetMap en Mapbox kaarten.",
                "Aanpasbare marker opties, inclusief kleur en SVG iconen.",
                "Instellingen voor kaarttype, kleur, zoomniveau en meer."
            ]
        }
    },
    "supports": {
        "html": false,
        "align": true,
        "anchor": true
    },
    "attributes": {
        "location": { "type": "string", "default": "" },
        "mapType": { "type": "string", "default": "osm" },
        "mapColor": { "type": "string", "default": "" },
        "latitude": { "type": "number", "default": 51.505 },
        "longitude": { "type": "number", "default": -0.09 },
        "zoom": { "type": "number", "default": 13 },
        "height": { "type": "string", "default": "400px" },
        "marker": { "type": "boolean", "default": true },
        "markerColor": { "type": "string", "default": "#1cacb4" },
        "markerSvg": { "type": "string", "default": "" },
        "markers": {
            "type": "array",
            "default": [],
            "items": { "type": "object" }
        },
        "markerLatitude": { "type": "number", "default": 51.505 },
        "markerLongitude": { "type": "number", "default": -0.09 },
        "markerPopup": { "type": "string", "default": "" }
    },
